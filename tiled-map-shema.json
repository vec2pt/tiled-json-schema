{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Map",
    "description": "Tiled can export maps as JSON files. To do so, simply select 'File > Export As' and select the JSON file type. You can export json from the command line with the `--export-map` option. The fields found in the JSON format differ slightly from those in the TMX Map Format, but the meanings should remain the same.",
    "type": "object",

    "$defs": {
        "def_property": {
            "type": "object",
            "additionalProperties": false,
            "required": [ "type", "propertytype", "value"],
            "properties": {
                "type": {
                    "type": "string",
                    "description": "Type of the property (`string` (default), `int`, float, bool, `color`, `file`, `object` or `class` (since 0.16, with `color` and `file` added in 0.17, `object` added in 1.4 and `class` added in 1.8))",
                    "enum": ["string", "int", "float", "bool", "color", "file", "object", "class" ],
                    "default": "string"
                },
                "propertytype": {
                    "type": "string",
                    "description": "Name of the custom property type, when applicable (since 1.8)"
                },
                "value": {
                    "description": "Value of the property"
                }
            }
        },

        "def_blend_mode": {
            "type": "string",
            "enum": [
                "normal",
                "add",
                "multiply",
                "screen",
                "overlay",
                "darken",
                "lighten",
                "color-dodge",
                "color-burn",
                "hard-light",
                "soft-light",
                "difference",
                "exclusion"
            ],
            "default": "normal"
        },
        "def_chunk": {
            "type": "object",
            "additionalProperties": false,
            "required": [ "data", "height", "width", "x", "y"],
            "properties": {
                "data": {
                    "description": "Array of unsigned int (GIDs) or base64-encoded data.",
                    "oneOf": [
                        {
                            "type": "string",
                            "contentMediaType": "image/png",
                            "contentEncoding": "base64"
                        },
                        {
                            "type": "array",
                            "items": {
                                "type": "integer",
                                "minimum": 0
                            }
                        }
                    ]
                },
                "height": {
                    "type": "integer",
                    "description": "Row count",
                    "minimum": 1
                },
                "width": {
                    "type": "integer",
                    "description": "Row count",
                    "minimum": 1
                },
                "x": {
                    "type": "integer",
                    "description": "X coordinate in tiles"
                },
                "y": {
                    "type": "integer",
                    "description": "Y coordinate in tiles"
                }
            }
        },
        "def_point": {
            "type": "object",
            "description": "A point on a polygon or a polyline, relative to the position of the object.",
            "additionalProperties": false,
            "required": ["x", "y"],
            "properties": {
                "x": {
                    "type": "number",
                    "description": "X coordinate in pixels"
                },
                "y": {
                    "type": "number",
                    "description": "Y coordinate in pixels"
                }
            }
        },
        "def_text": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text"],
            "properties": {
                "bold": {
                    "type": "boolean",
                    "description": "Whether to use a bold font (default: `false`)",
                    "default": false
                },
                "color": {
                    "type": "string",
                    "description": "Hex-formatted color (#RRGGBB or #AARRGGBB) (default: `#000000`)",
                    "pattern": "^#([A-F0-9]{6}|[A-F0-9]{8})$",
                    "default": "#000000"
                },
                "fontfamily": {
                    "type": "string",
                    "description": "Font family (default: `sans-serif`)",
                    "default": "sans-serif"
                },
                "halign" : {
                    "type": "string",
                    "description": "Horizontal alignment (`center`, `right`, `justify` or `left` (default))",
                    "enum": ["center", "right", "justify", "left"],
                    "default": "left"
                },
                "italic": {
                    "type": "boolean",
                    "description": "Whether to use an italic font (default: `false`)",
                    "default": false
                },
                "kerning": {
                    "type": "boolean",
                    "description": "Whether to use kerning when placing characters (default: `true`)",
                    "default": true
                },
                "pixelsize": {
                    "type": "integer",
                    "description": "Pixel size of font (default: 16)",
                    "default": 16
                },
                "strikeout": {
                    "type": "boolean",
                    "description": "Whether to strike out the text (default: `false`)",
                    "default": false
                },
                "text" : {
                    "type": "string",
                    "description": "Text"
                },
                "underline" : {
                    "type": "boolean",
                    "description": "Whether to underline the text (default: `false`)",
                    "default": false
                },
                "valign" : {
                    "type": "string",
                    "description": "Vertical alignment (`center`, `bottom` or `top` (default))",
                    "enum": ["center", "bottom", "top"],
                    "default": "top"
                },
                "wrap" : {
                    "type": "boolean",
                    "description": "Whether the text is wrapped within the object bounds (default: `false`)",
                    "default": false
                }
            }
        },
        "def_object": {
            "type": "object",
            "additionalProperties": false,
            "required": ["capsule", "ellipse", "height", "id", "name", "opacity", "point", "rotation", "type", "visible", "width", "x", "y"],
            "properties": {
                "capsule": {
                    "type": "boolean",
                    "description": "Used to mark an object as a capsule"
                },
                "ellipse": {
                    "type": "boolean",
                    "description": "Used to mark an object as an ellipse"
                },
                "gid": {
                    "type": "integer",
                    "description": "Global tile ID, only if object represents a tile"
                },
                "height": {
                    "type": "number",
                    "description": "Width in pixels",
                    "minimum": 0
                },
                "id": {
                    "type": "integer",
                    "description": "Incremental ID, unique across all objects"
                },
                "name": {
                    "type": "string",
                    "description": "String assigned to name field in editor"
                },
                "opacity": {
                    "type": "number",
                    "description": "The opacity of the object as a value from 0 to 1 (default: 1)",
                    "default": 1,
                    "minimum": 0,
                    "maximum": 1
                },
                "point": {
                    "type": "boolean",
                    "description": "Used to mark an object as a point"
                },
                "polygon": {
                    "type": "array",
                    "description": "Array of Points, in case the object is a polygon",
                    "minItems": 3,
                    "items": { "$ref": "#/$defs/def_point" }
                },
                "polyline": {
                    "type": "array",
                    "description": "Array of Points, in case the object is a polyline",
                    "minItems": 2,
                    "items": { "$ref": "#/$defs/def_point" }
                },
                "properties": {
                    "type": "array",
                    "description": "Array of Properties",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/def_property" }
                },
                "rotation": {
                    "type": "number",
                    "description": "Angle in degrees clockwise"
                },
                "template": {
                    "type": "string",
                    "description": "Reference to a template file, in case object is a template instance"
                },
                "text": {
                    "description": "Only used for text objects",
                    "$ref": "#/$defs/def_text"
                },
                "type": {
                    "type": "string",
                    "description": "The class of the object (was saved as `class` in 1.9, optional)"
                },
                "visible": {
                    "type": "boolean",
                    "description": "Whether object is shown in editor."
                },
                "width": {
                    "type": "number",
                    "description": "Width in pixels",
                    "minimum": 0
                },
                "x": {
                    "type": "number",
                    "description": "X coordinate in pixels"
                },
                "y": {
                    "type": "number",
                    "description": "Y coordinate in pixels"
                }
            }
        },
        "def_layer": {
            "type": "object",
            "additionalProperties": false,
            "required": [ "compression", "encoding", "id", "name", "opacity", "type", "visible", "x", "y"],
            "properties": {
                "chunks": {
                    "type": "array",
                    "description": "Array of chunks (optional). `tilelayer` only.",
                    "items": { "$ref": "#/$defs/def_chunk" }
                },
                "class": {
                    "type": "string",
                    "description": "The class of the layer (since 1.9, optional)"
                },
                "compression": {
                    "type": "string",
                    "description": "`zlib`, `gzip`, `zstd` (since 1.3) or empty (default). `tilelayer` only.",
                    "enum": [ "zlib", "gzip", "zstd", ""],
                    "default": ""
                },
                "data": {
                    "description": "Array of `unsigned int` (GIDs) or base64-encoded data. `tilelayer` only.",
                    "oneOf": [
                        {
                            "type": "string",
                            "contentMediaType": "image/png",
                            "contentEncoding": "base64"
                        },
                        {
                            "type": "array",
                            "items": {
                                "type": "integer",
                                "minimum": 0
                            }
                        }
                    ]
                },
                "draworder": {
                    "type": "string",
                    "description": "`topdown` (default) or `index`. `objectgroup` only.",
                    "enum": [ "topdown", "index"],
                    "default": "topdown"
                },
                "encoding": {
                    "type": "string",
                    "description": "`csv` (default) or `base64`. `tilelayer` only.",
                    "enum": [ "csv", "base64"],
                    "default": "csv"
                },
                "height": {
                    "type": "integer",
                    "description": "Row count. Same as map height for fixed-size maps. `tilelayer` only.",
                    "minimum": 1
                },
                "id": {
                    "type": "integer",
                    "description": "Incremental ID - unique across all layers"
                },
                "image" : {
                    "type": "string",
                    "description": "Image used by this layer. `imagelayer` only."
                },
                "imageheight": {
                    "type": "integer",
                    "description": "Height of the image used by this layer. `imagelayer` only. (since 1.11.1)"
                },
                "imagewidth": {
                    "type": "integer",
                    "description": "Width of the image used by this layer. `imagelayer` only. (since 1.11.1)"
                },
                "layers" : {
                    "type": "array",
                    "description": "Array of layers. `group` only.",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/def_layer" }
                },
                "locked": {
                    "type": "boolean",
                    "description": "Whether layer is locked in the editor (default: false). (since 1.8.2)",
                    "default": false

                },
                "mode": {
                    "description": "The blend mode to use when rendering the layer. (since 1.12)",
                    "$ref": "#/$defs/def_blend_mode"
                },
                "name": {
                    "type": "string",
                    "description": "Name assigned to this layer"
                },
                "objects": {
                    "type": "array",
                    "description": "Array of objects. `objectgroup` only.",
                    "items": { "$ref": "#/$defs/def_object" }
                },
                "offsetx": {
                    "type": "number",
                    "description": "Horizontal layer offset in pixels (default: 0)",
                    "default": 0
                },
                "offsety": {
                    "type": "number",
                    "description": "Vertical layer offset in pixels (default: 0)",
                    "default": 0
                },
                "opacity": {
                    "type": "number",
                    "description": "Value between 0 and 1 (default: 1)",
                    "default": 1,
                    "minimum": 0,
                    "maximum": 1
                },
                "parallaxx": {
                    "type": "number",
                    "description": "Horizontal parallax factor for this layer (default: 1). (since 1.5)",
                    "default": 1
                },
                "parallaxy": {
                    "type": "number",
                    "description": "Vertical parallax factor for this layer (default: 1). (since 1.5)",
                    "default": 1
                },
                "properties": {
                    "type": "array",
                    "description": "Array of Properties",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/def_property" }
                },
                "repeatx": {
                    "type": "boolean",
                    "description": "Whether the image drawn by this layer is repeated along the X axis. `imagelayer` only. (since 1.8)"
                },
                "repeaty": {
                    "type": "boolean",
                    "description": "Whether the image drawn by this layer is repeated along the Y axis. `imagelayer` only. (since 1.8)"
                },
                "startx": {
                    "type": "integer",
                    "description": "X coordinate where layer content starts (for infinite maps)"
                },
                "starty": {
                    "type": "integer",
                    "description": "Y coordinate where layer content starts (for infinite maps)"
                },
                "tintcolor": {
                    "type": "string",
                    "description": "Hex-formatted tint color (#RRGGBB or #AARRGGBB) that is multiplied with any graphics drawn by this layer or any child layers (optional).",
                    "pattern": "^#([A-F0-9]{6}|[A-F0-9]{8})$"
                },
                "transparentcolor": {
                    "type": "string",
                    "description": "Hex-formatted color (#RRGGBB) (optional). imagelayer only.",
                    "pattern": "^#([A-F0-9]{6})$"
                },
                "type": {
                    "type": "string",
                    "description": "`tilelayer`, `objectgroup`, `imagelayer` or `group`",
                    "enum": ["tilelayer", "objectgroup", "imagelayer", "group"]
                },
                "visible": {
                    "type": "boolean",
                    "description": "Whether layer is shown or hidden in editor"
                },
                "width": {
                    "type": "integer",
                    "description": "Column count. Same as map width for fixed-size maps. `tielayer` only.",
                    "minimum": 1
                },
                "x": {
                    "type": "integer",
                    "description": "Horizontal layer offset in tiles. Always 0.",
                    "const": 0
                },
                "y": {
                    "type": "integer",
                    "description": "Vertical layer offset in tiles. Always 0.",
                    "const": 0
                }
            }
        },
        "def_grid": {
            "type": "object",
            "description": "",
            "additionalProperties": false,
            "required": ["height", "width"],
            "properties": {
                "height": {
                    "type": "integer",
                    "description": "Cell height of tile grid"
                },
                "orientation": {
                    "type": "string",
                    "description": "`orthogonal` (default) or `isometric`",
                    "enum": ["orthogonal", "isometric"],
                    "default": "orthogonal"
                },
                "width": {
                    "type": "integer",
                    "description": "Cell width of tile grid"
                }
            }
        },
        "def_terrains": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "tile"],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Name of terrain",
                    "default": 0
                },
                "properties": {
                    "type": "array",
                    "description": "Array of Properties",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/def_property" }
                },
                "tile": {
                    "type": "integer",
                    "description": "Local ID of tile representing terrain"
                }
            }
        },
        "def_tileoffset": {
            "type": "object",
            "description": "See <tileoffset> in the TMX Map Format.",
            "additionalProperties": false,
            "required": ["x", "y"],
            "properties": {
                "x": {
                    "type": "integer",
                    "description": "Horizontal offset in pixels",
                    "default": 0
                },
                "y": {
                    "type": "integer",
                    "description": "Vertical offset in pixels (positive is down)",
                    "default": 0
                }
            }
        },
        "def_tile": {
            "type": "object",
            "description": "",
            "additionalProperties": false,
            "required": [],
            "properties": {}
        },
        "def_transformations": {
            "type": "object",
            "description": "See <transformations> in the TMX Map Format.",
            "additionalProperties": false,
            "required": [ "hflip", "vflip", "rotate", "preferuntransformed" ],
            "properties": {
                "hflip": {
                    "type": "boolean",
                    "description": "Tiles can be flipped horizontally",
                    "default": false
                },
                "vflip": {
                    "type": "boolean",
                    "description": "Tiles can be flipped horizontally",
                    "default": false
                },
                "rotate": {
                    "type": "boolean",
                    "description": "Tiles can be rotated in 90-degree increments",
                    "default": false
                },
                "preferuntransformed": {
                    "type": "boolean",
                    "description": "Whether untransformed tiles remain preferred, otherwise transformed tiles are used to produce more variations",
                    "default": false
                }
            }
        },
        "def_tileset": {
            "type": "object",
            "additionalProperties": false,
            "required": ["firstgid"],
            "properties": {
                "backgroundcolor": {
                    "type": "string",
                    "description": "Hex-formatted color (#RRGGBB or #AARRGGBB) (optional)",
                    "pattern": "^#([A-F0-9]{6}|[A-F0-9]{8})$"
                },
                "class": {
                    "type": "string",
                    "description": "The class of the tileset (since 1.9, optional)"
                },
                "columns": {
                    "type": "integer",
                    "description": "The number of tile columns in the tileset"
                },
                "fillmode": {
                    "type": "string",
                    "description": "The fill mode to use when rendering tiles from this tileset (`stretch` (default) or `preserve-aspect-fit`) (since 1.9)",
                    "enum": ["stretch", "preserve-aspect-fit"],
                    "default": "stretch"
                },
                "firstgid": {
                    "type": "integer",
                    "description": "GID corresponding to the first tile in the set"
                },
                "grid": {
                    "description": "(optional)",
                    "$ref": "#/$defs/def_grid"
                },
                "image": {
                    "type": "string",
                    "description": "Image used for tiles in this set"
                },
                "imageheight": {
                    "type": "integer",
                    "description": "Height of source image in pixels"
                },
                "imagewidth": {
                    "type": "integer",
                    "description": "Width of source image in pixels"
                },
                "margin": {
                    "type": "integer",
                    "description": "Buffer between image edge and first tile (pixels)"
                },
                "name": {
                    "type": "string",
                    "description": "Name given to this tileset"
                },
                "objectalignment": {
                    "type": "string",
                    "description": "Alignment to use for tile objects (`unspecified` (default), `topleft`, `top`, `topright`, `left`, `center`, `right`, `bottomleft`, `bottom` or `bottomright`) (since 1.4)",
                    "enum": ["unspecified", "topleft", "top", "topright", "left", "center", "right", "bottomleft", "bottom", "bottomright"],
                    "default": "unspecified"

                },
                "properties": {
                    "type": "array",
                    "description": "Array of Properties",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/def_property" }
                },
                "source": {
                    "type": "string",
                    "description": "The external file that contains this tilesets data"
                },
                "spacing": {
                    "type": "integer",
                    "description": "Spacing between adjacent tiles in image (pixels)"
                },
                "terrains": {
                    "type": "array",
                    "description": "Array of Terrains (optional)",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/def_terrains" }
                },
                "tilecount": {
                    "type": "integer",
                    "description": "The number of tilse in this tileset",
                    "minimum": 0
                },
                "tiledversion": {
                    "type": "string",
                    "description": "The Tilde version used to save the file"
                },
                "tileheight": {
                    "type": "integer",
                    "description": "Maximum height of tiles in this set"
                },
                "tileoffset": {
                    "description": "(optional)",
                    "$ref": "#/$defs/def_tileoffset"
                },
                "tilerendersize": {
                    "type": "string",
                    "description": "The size to use when rendering tiles from this tileset on a tile layer (`tile` (default) or `grid`) (since 1.9)",
                    "enum": ["tile", "grid"],
                    "default": "tile"
                },
                "tiles": {
                    "type": "array",
                    "description": "Array of Tiles (optional) (TODO)",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/def_tile" }
                },
                "tilewidth": {
                    "type": "integer",
                    "description": "Maximum width of tiles in this set"
                },
                "transformations": {
                    "description": "Allowed transformations (optional)",
                    "$ref": "#/$defs/def_transformations"
                },
                "transparentcolor": {
                    "type": "string",
                    "description": "Hex-formatted color (#RRGGBB) (optional)",
                    "pattern": "^#([A-F0-9]{6})$"
                },
                "type": {
                    "type": "string",
                    "description": "`tileset` (for tileset files, since 1.0)",
                    "const": "tileset"
                },
                "version": {
                    "type": "string",
                    "description": "The JSON format version (previously a number, saved as string since 1.6)"
                },
                "wangsets": {
                    "type": "array",
                    "description": "Array of Wang sets (since 1.1.5) (TODO)",
                    "minItems": 1
                }
            }
        }
    },

    "required": ["compressionlevel", "height", "infinite", "layers", "nextlayerid", "nextobjectid", "orientation", "renderorder", "tiledversion", "tileheight", "tilesets", "tilewidth", "type", "version", "width"],
    "additionalProperties": false,
    "properties": {
        "backgroundcolor": {
            "type": "string",
            "description": "Hex-formatted color (#RRGGBB or #AARRGGBB) (optional)",
            "pattern": "^#([A-F0-9]{6}|[A-F0-9]{8})$"
        },
        "class": {
            "type": "string",
            "description": "The class of the map (since 1.9, optional)"
        },
        "compressionlevel": {
            "type": "integer",
            "description": "The compression level to use for tile layer data (defaults to -1, which means to use the algorithm default)",
            "default": -1
        },
        "height": {
            "type": "integer",
            "description": "Number of tile rows",
            "minimum": 1
        },
        "hexsidelength": {
            "type": "integer",
            "description": "Length of the side of a hex tile in pixels (hexagonal maps only)"
        },
        "infinite": {
            "type": "boolean",
            "description": "Whether the map has infinite dimensions"
        },
        "layers": {
            "type": "array",
            "description": "Array of Layers",
            "minItems": 1,
            "items": { "$ref": "#/$defs/def_layer" }
        },
        "nextlayerid": {
            "type": "integer",
            "description": "Auto-increments for each layer"
        },
        "nextobjectid": {
            "type": "integer",
            "description": "Auto-increments for each placed object"
        },
        "orientation": {
            "type": "string",
            "description": "`orthogonal`, `isometric`, `staggered` or `hexagonal`",
            "enum": [ "orthogonal", "isometric", "staggered", "hexagonal"]
        },
        "parallaxoriginx": {
            "type": "number",
            "description": "X coordinate of the parallax origin in pixels (since 1.8, default: 0)",
            "default": 0
        },
        "parallaxoriginy": {
            "type": "number",
            "description": "Y coordinate of the parallax origin in pixels (since 1.8, default: 0)",
            "default": 0
        },
        "properties": {
            "type": "array",
            "description": "Array of Properties",
            "minItems": 1,
            "items": { "$ref": "#/$defs/def_property" }
        },
        "renderorder": {
            "type": "string",
            "description": "`right-down` (the default), `right-up`, `left-down` or `left-up` (currently only supported for orthogonal maps)",
            "enum": [ "right-down", "right-up", "left-down", "left-up"],
            "default": "right-down"
        },
        "staggeraxis": {
            "type": "string",
            "description": "`x` or `y` (staggered / hexagonal maps only)",
            "enum": [ "x", "y"]
        },
        "staggerindex": {
            "type": "string",
            "description": "`odd` or `even` (staggered / hexagonal maps only)",
            "enum": [ "odd", "even"]
        },
        "tiledversion": {
            "type": "string",
            "description": "The Tilde version used to save the file"
        },
        "tileheight": {
            "type": "integer",
            "description": "Map grid height",
            "minimum": 1
        },
        "tilesets": {
            "type": "array",
            "description": "Array of Tilesets",
            "minItems": 1,
            "items": { "$ref": "#/$defs/def_tileset" }
        },
        "tilewidth": {
            "type": "integer",
            "description": "Map grid width",
            "minimum": 1
        },
        "type": {
            "type": "string",
            "description": "`map` (since 1.0)",
            "const": "map"
        },
        "version": {
            "type": "string",
            "description": "The JSON format version (previously a number, saved as string since 1.6)"
        },
        "width": {
            "type": "integer",
            "description": "Number of tile columns",
